{
    "name": "qordy/restaurant-saas",
    "description": "A comprehensive restaurant management SaaS application with QR ordering, POS, and kitchen display system",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "QORDY Development Team",
            "email": "dev@qordy.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "ext-pdo": "*",
        "ext-redis": "*",
        "vlucas/phpdotenv": "^5.5",
        "phpmailer/phpmailer": "^6.9",
        "cboden/ratchet": "^0.4.4",
        "iyzico/iyzipay-php": "^2.0",
        "endroid/qr-code": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers/functions.php",
            "app/helpers/auth.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"copy('.env.example', '.env');\""
        ],
        "check-redis": "php -r \"if (!extension_loaded('redis')) { echo 'WARNING: Redis extension is not loaded. Install it with: pecl install redis\\n'; exit(1); } else { echo 'Redis extension is loaded.\\n'; }\"",
        "test": "phpunit",
        "test-unit": "phpunit --testsuite=Unit",
        "test-integration": "phpunit --testsuite=Integration",
        "test-feature": "phpunit --testsuite=Feature",
        "test-coverage": "phpunit --coverage-html tests/coverage"
    }
}
