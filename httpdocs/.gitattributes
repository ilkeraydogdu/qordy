# Auto detect text files and perform LF normalization
* text=auto

# PHP
*.php text eol=lf
*.phtml text eol=lf

# JavaScript
*.js text eol=lf
*.json text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf

# HTML/XML
*.html text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Shell scripts
*.sh text eol=lf

# SQL
*.sql text eol=lf

# Config files
.htaccess text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf

# Markdown
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.pdf binary
