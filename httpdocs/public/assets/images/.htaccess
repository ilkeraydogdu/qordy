# Qordy: assets/images dizininde PHP/CGI yürütmeyi KAPAT
# Logo/favicon upload yollarında ek savunma (uzantı bypass olsa dahi).

<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

<FilesMatch "\.(php|phtml|phar|php3|php4|php5|php7|php8|phps|pht|cgi|pl|py|rb|sh|asp|aspx|jsp)$">
    SetHandler none
    RemoveHandler .php .phtml .phar .php3 .php4 .php5 .php7 .php8 .phps .pht
    RemoveType .php .phtml .phar
    ForceType application/octet-stream
    Header set Content-Disposition "attachment"
    Require all denied
</FilesMatch>

<Files ".htaccess">
    Require all denied
</Files>
<Files ".user.ini">
    Require all denied
</Files>

Options -Indexes -ExecCGI
