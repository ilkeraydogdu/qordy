<?xml version="1.0" encoding="utf-8"?>
<!--
  Prevent user data (EncryptedSharedPreferences, secure storage, logs)
  from being included in either cloud backups or device-to-device
  transfers. Business tokens should never leave the device they were
  minted on.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
